# ============================================================
# Fiscal Document Extractor - environment configuration
# Copy this file to .env and fill in the values.
# ============================================================

# --- API ---
APP_ENV=development            # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=*                 # comma-separated list or '*'

# --- Auth ---
# HS256 shared secret. In production use a 64+ char random string.
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
# Set to false to disable auth (dev only).
AUTH_ENABLED=true

# --- LLM (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.0
LLM_TIMEOUT_SECONDS=90

# --- Files ---
MAX_FILE_SIZE_MB=20
ACCEPTED_MIMETYPES=application/pdf,image/jpeg,image/png,image/webp,text/xml,application/xml,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# --- OCR ---
OCR_ENGINE=tesseract           # tesseract | surya
OCR_LANGUAGE=por
OCR_DPI=220
# Windows dev only: absolute path to tesseract.exe and poppler bin folder
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# POPPLER_PATH=C:\poppler\Library\bin
# Set when the language pack (e.g. por.traineddata) lives outside the default
# tessdata folder. Useful for dev environments without admin rights.
# TESSDATA_PREFIX=D:\path\to\project\tessdata

# --- Confidence ---
CONFIDENCE_THRESHOLD=0.70

# --- Cost-control pipeline ---
# When true, try deterministic regex parsers before the LLM.
# Typical savings in production: 70-90% of requests skip the LLM entirely.
ENABLE_HEURISTIC=true
HEURISTIC_MIN_CONFIDENCE=0.70

# Content-addressable cache (sha256 of the uploaded file).
# Successful extractions are persisted to CACHE_DIR and reused forever.
# Disable for privacy-sensitive deployments.
ENABLE_CACHE=true
CACHE_DIR=.cache/extractions

# Hard-cap LLM spend: fails with HEURISTIC_INSUFFICIENT when the regex
# layer can't reach HEURISTIC_MIN_CONFIDENCE. Use for "cheap tier".
DISABLE_LLM_FALLBACK=false

# --- Async / Celery (optional) ---
ENABLE_CELERY=false
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
